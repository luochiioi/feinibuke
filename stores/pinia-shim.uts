// Minimal Pinia-compatible defineStore shim for uniapp x
// Replaces `import { defineStore } from 'pinia'` with this local implementation

type StoreSetup = () => Record<string, any> | Map<string, any>

export function defineStore(_id: string, setup: StoreSetup): () => any {
  let instance: any = null
  return (): any => {
    if (instance != null) return instance
    instance = setup()
    return instance
  }
}
