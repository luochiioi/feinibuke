	line-height: 60rpx;
}

.comfirm-btn {
	width: 100%;
	height: 90rpx;
	background-color: #1a5599; 
	color: #ffffff;
	font-size: 34rpx;
	font-weight: bold;
	border-radius: 45rpx;
	margin-top: 60rpx;
	box-shadow: 0 8rpx 16rpx rgba(26, 85, 153, 0.3);
}

