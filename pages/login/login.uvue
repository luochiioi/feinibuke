	width: 100%;
	background-color: #ffffff;
	padding: 60rpx 50rpx;
	border-radius: 24rpx;
	box-shadow: 0 10rpx 30rpx rgba(26, 85, 153, 0.15);
	border: 2rpx solid #e6f0fa;
}

