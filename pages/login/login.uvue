	opacity: 0.9;
	transform: translateY(2rpx);
	box-shadow: 0 4rpx 8rpx rgba(26, 85, 153, 0.3);
}

.links-group {
	display: flex;
	flex-direction: column;
	align-items: center;
	margin-top: 50rpx;
}

.resetPassword-text {
	font-size: 28rpx;
	color: #1a5599;
	margin-bottom: 30rpx;
}

.signUp-text {
	font-size: 26rpx;
	color: #7a8b9a;
}
</style>