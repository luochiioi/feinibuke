  font-size: 24rpx;
  color: #999999;
  font-family: monospace;
  margin-top: 8rpx;
}

.gps-section {
  padding: 24rpx 32rpx;
}

.gps-card {
  padding: 24rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
}

.gps-card.in-range {
  background-color: #e6f9ed;
}

.gps-card.out-range {
  background-color: #fde8e8;
}

.gps-label {
  font-size: 28rpx;
  font-weight: 500;
}

.in-range .gps-label { color: #27ae60; }
.out-range .gps-label { color: #e74c3c; }

.gps-distance {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.gps-accuracy {
  font-size: 24rpx;
  color: #888888;
}

.photo-section {
  padding: 0 32rpx 24rpx;
}

.photo-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #ffffff;
  border: 2rpx dashed #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.photo-icon {
  font-size: 48rpx;
}

.photo-hint {
  font-size: 22rpx;
  color: #999999;
}

.compress-hint {
  font-size: 22rpx;
  color: #f39c12;
  margin-top: 8rpx;
}

.note-section {
  padding: 0 32rpx 24rpx;
}

.note-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.note-input {
  width: 100%;
  height: 160rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.note-placeholder {
  color: #bbbbbb;
}

.note-count {
  font-size: 22rpx;
  color: #cccccc;
  text-align: right;
  margin-top: 8rpx;
}

.submit-section {
  padding: 24rpx 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background-color: #2ecc71;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 204, 113, 0.35);
}

.submit-btn.disabled {
  background-color: #cccccc;
  box-shadow: none;
}

.btn-hover {
  opacity: 0.9;
  transform: translateY(2rpx);
}
</style>
