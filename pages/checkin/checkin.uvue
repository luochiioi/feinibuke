<template>
  <view class="checkin-page">
    <!-- Header -->
    <view class="header">
      <text class="marker-title">{{ markerTitle }}</text>
      <text class="marker-coord" v-if="marker">
        {{ marker.latitude.toFixed(6) }}, {{ marker.longitude.toFixed(6) }}
      </text>
    </view>

    <!-- Distance & GPS info -->
    <view class="gps-section">
      <view class="gps-card" :class="withinRange ? 'in-range' : 'out-range'">
        <text class="gps-label">{{ withinRange ? 'ењЁж‰“еЌЎиЊѓе›ґе†…' : 'и·ќз¦»иї‡иїњ' }}</text>
        <text class="gps-distance" v-if="distance != null">{{ formatDistance(distance) }}</text>
        <text class="gps-accuracy">{{ locationStore.accuracyText }}</text>
      </view>
    </view>

    <!-- Photo picker -->
    <view class="photo-section">
      <view class="photo-preview" @click="choosePhoto">
        <image v-if="photoPath" :src="photoPath" class="photo-image" />
        <view v-else class="photo-placeholder">
          <text class="photo-icon">рџ“·</text>
          <text class="photo-hint">з‚№е‡»ж‹Ќз…§ж€–йЂ‰ж‹©з…§з‰‡</text>
        </view>
      </view>
      <text class="compress-hint" v-if="isCompressing">еЋ‹зј©дё?..</text>
    </view>

    <!-- Note input -->
    <view class="note-section">
      <text class="note-label">ж‰“еЌЎе¤‡жіЁпј€йЂ‰еЎ«пј?/text>
      <textarea
        class="note-input"
        v-model="note"
        placeholder="и®°еЅ•ж­¤е€»зљ„еїѓжѓ?.."
        placeholder-class="note-placeholder"
        maxlength="200"
      />
      <text class="note-count">{{ note.length }}/200</text>
    </view>

    <!-- Submit button -->
    <view class="submit-section">
      <button
        class="submit-btn"
        :class="{ disabled: !canSubmit }"
        :disabled="!canSubmit"
        hover-class="btn-hover"
        @click="submitCheckIn"
      >
        {{ isSubmitting ? 'ж‰“еЌЎдё?..' : 'зЎ®и®¤ж‰“еЌЎ' }}
      </button>
    </view>
  </view>
</template>

<script setup lang="uts">
import { ref, computed, onShow, onHide } from 'vue'
import { useMarkerStore } from '@/stores/useMarkerStore'
import { useLocationStore } from '@/stores/useLocationStore'
import { useTaskStore } from '@/stores/useTaskStore'
import { formatDistance } from '@/utils/format'
import { enqueueAction } from '@/utils/cloudSync'

const markerStore = useMarkerStore()
const locationStore = useLocationStore()
const taskStore = useTaskStore()

const markerId = ref<number>(0)
const markerTitle = ref<string>('')
const photoPath = ref<string | null>(null)
const cloudURL = ref<string | null>(null)
const note = ref<string>('')
const isCompressing = ref<boolean>(false)
const isSubmitting = ref<boolean>(false)

const marker = computed(() => markerStore.findById(markerId.value))

const distance = computed(() => {
  if (!marker.value || !locationStore.currentLocation) return null
  return locationStore.distanceTo(marker.value.latitude, marker.value.longitude)
})

const effectiveRadius = computed(() => {
  return 500 + Math.min(locationStore.accuracy * 0.5, 200)
})

const withinRange = computed(() => {
  return distance.value !== null && distance.value <= effectiveRadius.value
})

const canSubmit = computed(() => {
  return withinRange.value && !isSubmitting.value
})

onShow((): void => {
  const pages = getCurrentPages()
  const currentPage = pages[pages.length - 1] as any
  const query = currentPage?.$page?.options ?? {}
  markerId.value = parseInt(query.id ?? '0')
  markerTitle.value = decodeURIComponent(query.title ?? '')
  locationStore.startPolling(5000)
})

onHide((): void => {
  locationStore.stopPolling()
})

async function choosePhoto(): Promise<void> {
  uni.showActionSheet({
    itemList: ['ж‹Ќз…§', 'д»Ћз›ёе†ЊйЂ‰ж‹©'],
    success: async (res: any) => {
      const sourceType = res.tapIndex === 0 ? ['camera'] : ['album']
      uni.chooseImage({
        count: 1,
        sizeType: ['compressed'],
        sourceType: sourceType,
        success: async (imgRes: any) => {
          let path: string = imgRes.tempFilePaths[0] as string

          const fileInfo = await getFileInfoAsync(path)
          if (fileInfo.size > 1024 * 1024) {
            isCompressing.value = true
            path = await compressImageAsync(path)
            isCompressing.value = false
          }
          photoPath.value = path
        }
      })
    }
  })
}

async function submitCheckIn(): Promise<void> {
  if (!withinRange.value || !marker.value) return

  isSubmitting.value = true

  try {
    // Upload photo to cloud if available
    if (photoPath.value) {
      try {
        const fs = uni.getFileSystemManager()
        const base64Data = fs.readFileSync(photoPath.value, 'base64') as string
        const photoApi = uniCloud.importObject('photo-center')
        const uploadRes = await photoApi.upload({
          fileContent: base64Data,
          fileName: `checkin_${Date.now()}.jpg`
        }) as UTSJSONObject
        const uploadData = uploadRes["data"] as UTSJSONObject
        cloudURL.value = uploadData["cloudURL"] as string
      } catch (e) {
        console.log('Photo upload failed, continuing with local only', e)
      }
    }

    // Cloud checkin
    try {
      const markerApi = uniCloud.importObject('marker-center')
      const checkinRes = await markerApi.checkin({
        markerId: markerId.value,
        photoCloudURL: cloudURL.value,
        note: note.value || null,
        latitude: locationStore.currentLocation?.latitude,
        longitude: locationStore.currentLocation?.longitude
      }) as UTSJSONObject
      const errCode = checkinRes["errCode"] as number
      if (errCode !== 0) {
        const errMsg = checkinRes["errMsg"] as string
        uni.showToast({ title: errMsg, icon: 'none' })
        isSubmitting.value = false
        return
      }
    } catch (e) {
      console.log('Cloud checkin failed, queuing for later sync', e)
      enqueueAction('checkin', {
        markerId: markerId.value,
        photoCloudURL: cloudURL.value,
        note: note.value || null,
        latitude: locationStore.currentLocation?.latitude,
        longitude: locationStore.currentLocation?.longitude
      })
    }

    // Local update (optimistic)
    await markerStore.doCheckIn(markerId.value, photoPath.value, note.value || null)
    const completed = taskStore.checkTaskCompletion(marker.value)

    uni.showToast({ title: 'ж‰“еЌЎж€ђеЉџпј?, icon: 'success' })
    if (completed && completed.length > 0) {
      setTimeout(() => {
        uni.showToast({ title: `е®Њж€ђд»»еЉЎпј?{completed[0].name}`, icon: 'none' })
      }, 1000)
    }
    setTimeout(() => uni.navigateBack(), 1500)
  } catch (e) {
    uni.showToast({ title: 'ж‰“еЌЎе¤±иґҐ', icon: 'error' })
    isSubmitting.value = false
  }
}

function getFileInfoAsync(path: string): Promise<{ size: number }> {
  return new Promise((resolve) => {
    uni.getFileInfo({ filePath: path, success: (res: any) => resolve(res) })
  })
}

function compressImageAsync(path: string): Promise<string> {
  return new Promise((resolve) => {
    uni.compressImage({ src: path, quality: 80, success: (res: any) => resolve(res.tempFilePath) })
  })
}
</script>

<style>
.checkin-page {
  flex: 1;
  background-color: #f5f7f5;
  min-height: 800px;
}

.header {
  padding: 40rpx 32rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e8ece8;
}

.marker-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
}

