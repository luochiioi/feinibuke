}
.source-row .source-chip + .source-chip,
.source-row .refresh-btn + .refresh-btn,
.source-row .source-chip + .refresh-btn,
.source-row .refresh-btn + .source-chip { margin-left: 12rpx; }

.source-chip,
.refresh-btn {
	padding: 16rpx 20rpx;
	border-radius: 999rpx;
	font-size: 22rpx;
	font-weight: bold;
}

.source-chip {
	background: rgba(20, 33, 61, 0.04);
	color: #5b6475;
