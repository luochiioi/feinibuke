<template>
	<view class="add-page">
		<view class="hero-section">
			<text class="hero-tag">NEW SPOT</text>
			<text class="hero-title">新增地点</text>
			<text class="hero-subtitle">默认带入地图中心或当前位置，补上名称后就可以直接保存。</text>
		</view>

		<view class="content-card source-card">
			<view class="section-head">
				<text class="section-title">坐标来源</text>
				<text class="section-note">更适合手机端的添加方式</text>
			</view>

			<view class="source-row">
				<view
					:class="['source-chip', activeSource === 'center' ? 'source-chip--active' : '', mapCenterNull ? 'source-chip--disabled' : '']"
					@click="applyCoordinates('center')"
				>
					地图中心
				</view>
				<view
					:class="['source-chip', activeSource === 'current' ? 'source-chip--active' : '', currentLocationNull ? 'source-chip--disabled' : '']"
					@click="applyCoordinates('current')"
				>
					我的位置
				</view>
				<view class="refresh-btn" @click="refreshCurrentLocation">刷新定位</view>
			</view>

			<text class="source-tip">
				{{ sourceTip }}
			</text>
		</view>

		<view class="content-card form-card">
			<view class="section-head">
				<text class="section-title">地点信息</text>
				<text class="section-note">支持手动微调坐标</text>
			</view>

			<view class="field-group">
				<text class="field-label">地点名称</text>
				<input v-model.trim="formTitle" class="field-input" maxlength="24" placeholder="例如：鼓浪屿日光岩" />
			</view>

			<view class="field-grid">
				<view class="field-group field-group--half">
					<text class="field-label">纬度</text>
					<input
						v-model="formLatitude"
						class="field-input"
						type="digit"
						placeholder="请输入纬度"
					/>
				</view>
				<view class="field-group field-group--half">
					<text class="field-label">经度</text>
					<input
						v-model="formLongitude"
						class="field-input"
						type="digit"
						placeholder="请输入经度"
					/>
				</view>
			</view>

			<view class="preview-card">
				<text class="preview-label">当前坐标预览</text>
				<text class="preview-value">{{ previewCoordinates }}</text>
			</view>

			<view class="action-row">
				<button class="secondary-btn" @click="goBack">取消</button>
				<button class="primary-btn" @click="submitForm">保存地点</button>
			</view>
		</view>
	</view>
</template>

<script lang="ts">
import { addMarkerCloud } from '@/utils/map-storage.uts';

export default {
	data() {
		return {
			formTitle: '',
			formLatitude: '',
			formLongitude: '',
			// P2-#15：null 表示未设置；-1 在赤道/本初子午线属合法坐标，不能作哨兵
			mapCenterLat: null as number | null,
			mapCenterLng: null as number | null,
			mapCenterValid: false,
			currentLat: null as number | null,
			currentLng: null as number | null,
			currentLocationValid: false,
			activeSource: '',
			isLoadingLocation: false
		};
	},
	computed: {
		sourceTip() : string {
			if (this.activeSource === 'current' && this.currentLocationValid && this.currentLat != null && this.currentLng != null) {
				return `当前使用”我的位置”：${this.currentLat!!.toFixed(6)}, ${this.currentLng!!.toFixed(6)}`;
			}
			if (this.activeSource === 'center' && this.mapCenterValid && this.mapCenterLat != null && this.mapCenterLng != null) {
				return `当前使用”地图中心”：${this.mapCenterLat!!.toFixed(6)}, ${this.mapCenterLng!!.toFixed(6)}`;
			}
			return '没有自动坐标时，也可以直接手动输入经纬度。';
		},
		mapCenterNull() : boolean {
			return !this.mapCenterValid;
		},
		currentLocationNull() : boolean {
			return !this.currentLocationValid;
		},
		previewCoordinates() : string {
			const latitude = this.parseCoordinate(this.formLatitude);
			const longitude = this.parseCoordinate(this.formLongitude);
			if (latitude == null || longitude == null) {
				return '等待填写';
			}
			return `${latitude!!.toFixed(6)}, ${longitude!!.toFixed(6)}`;
		}
	},
	onLoad(query) {
		const centerLatRaw = query != null ? query["centerLat"] : null;
		const centerLngRaw = query != null ? query["centerLng"] : null;
		const currentLatRaw = query != null ? query["currentLat"] : null;
		const currentLngRaw = query != null ? query["currentLng"] : null;

		const centerLat = this.parseCoordinate(centerLatRaw);
		const centerLng = this.parseCoordinate(centerLngRaw);
		const curLat = this.parseCoordinate(currentLatRaw);
		const curLng = this.parseCoordinate(currentLngRaw);

		if (centerLat != null && centerLng != null) {
			this.mapCenterLat = centerLat!!;
			this.mapCenterLng = centerLng!!;
			this.mapCenterValid = true;
		}

		if (curLat != null && curLng != null) {
			this.currentLat = curLat!!;
			this.currentLng = curLng!!;
			this.currentLocationValid = true;
		}

		if (this.mapCenterValid) {
			this.applyCoordinates('center');
		} else if (this.currentLocationValid) {
			this.applyCoordinates('current');
		} else {
			this.refreshCurrentLocation();
		}
	},
	methods: {
		parseCoordinate(value : any | null) : number | null {
			if (value == null) {
				return null;
			}
			const str = '' + value;
			if (str == '') {
				return null;
			}
			const parsed = parseFloat(str);
			return isFinite(parsed) ? parsed : null;
		},
		fillFormCoordinates(lat : number, lng : number) {
			this.formLatitude = lat.toFixed(6);
			this.formLongitude = lng.toFixed(6);
		},
		applyCoordinates(source : string) {
			if (source === 'center') {
				if (!this.mapCenterValid || this.mapCenterLat == null || this.mapCenterLng == null) {
					return;
				}
				this.fillFormCoordinates(this.mapCenterLat!!, this.mapCenterLng!!);
				this.activeSource = 'center';
				return;
			}
			if (!this.currentLocationValid || this.currentLat == null || this.currentLng == null) {
				this.refreshCurrentLocation();
				return;
			}
			this.fillFormCoordinates(this.currentLat!!, this.currentLng!!);
			this.activeSource = 'current';
		},
		refreshCurrentLocation() {
			if (this.isLoadingLocation) {
				return;
			}
			this.isLoadingLocation = true;
			uni.getLocation({
				type: 'gcj02',
				isHighAccuracy: true,
				highAccuracyExpireTime: 3000,
				success: (res) => {
					this.currentLat = res.latitude;
					this.currentLng = res.longitude;
					this.currentLocationValid = true;
					if (this.formLatitude == '' || this.formLongitude == '' || this.activeSource === 'current') {
						this.applyCoordinates('current');
					}
				},
				fail: () => {
					uni.showToast({
						title: '获取定位失败，请手动填写坐标',
						icon: 'none'
					});
				},
				complete: () => {
					this.isLoadingLocation = false;
				}
			});
		},
		async submitForm() {
			const title = this.formTitle.trim();
			const latitude = this.parseCoordinate(this.formLatitude);
			const longitude = this.parseCoordinate(this.formLongitude);

			if (title == '') {
				uni.showToast({ title: '请先填写地点名称', icon: 'none' });
				return;
			}

			if (latitude == null || longitude == null) {
				uni.showToast({ title: '请填写有效的经纬度', icon: 'none' });
				return;
			}

			const lat = latitude!!;
			const lng = longitude!!;
			if (lat < -90 || lat > 90 || lng < -180 || lng > 180) {
				uni.showToast({ title: '经纬度超出范围', icon: 'none' });
				return;
			}

			uni.showLoading({ title: '保存中…', mask: true });
			try {
				await addMarkerCloud({ title: title, latitude: lat, longitude: lng });
				uni.hideLoading();
				uni.showToast({ title: '地点已保存', icon: 'success' });
				setTimeout((): void => { uni.navigateBack() }, 450);
			} catch (e) {
				uni.hideLoading();
				uni.showToast({ title: '保存失败，请重试', icon: 'none' });
			}
		},
		goBack() {
			uni.navigateBack();
		}
	}
};
</script>

