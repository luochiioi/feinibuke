	margin-top: 22rpx;
}

.field-grid {
	display: flex;
	flex-wrap: wrap;
}
.field-grid .field-group--half + .field-group--half { margin-left: 14rpx; }

.field-group--half {
	flex: 1;
	min-width: 0;
}

.field-label {
	margin-bottom: 12rpx;
	font-size: 22rpx;
	font-weight: bold;
