	display: flex;
	align-items: center;
	padding: 24rpx 28rpx;
	border-radius: 26rpx;
	margin-bottom: 20rpx;
}
.status-banner .banner-icon { margin-right: 16rpx; }

.banner-done {
	background: linear-gradient(135deg, rgba(52, 199, 89, 0.12), rgba(52, 199, 89, 0.06));
	border: 1px solid rgba(52, 199, 89, 0.25);
}

.banner-pending {
	background: linear-gradient(135deg, rgba(255, 149, 0, 0.12), rgba(255, 149, 0, 0.06));
	border: 1px solid rgba(255, 149, 0, 0.25);
}

.banner-icon { font-size: 44rpx; }
.banner-text { font-size: 28rpx; font-weight: 700; color: #14213d; }

.info-card {
	padding: 28rpx 24rpx;
	border-radius: 28rpx;
	background: rgba(255, 253, 250, 0.97);
	border: 1px solid rgba(20, 33, 61, 0.06);
	box-shadow: 0 12rpx 32rpx rgba(31, 41, 55, 0.08);
	margin-bottom: 18rpx;
}

.task-title {
	font-size: 40rpx;
	font-weight: 700;
	color: #14213d;
}

.task-desc {
	margin-top: 12rpx;
	font-size: 26rpx;
	color: #6b7280;
	line-height: 1.6;
}

.info-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	margin-top: 22rpx;
	padding-top: 22rpx;
	border-top: 1px solid rgba(20, 33, 61, 0.06);
}

.info-label { font-size: 26rpx; color: #7b8496; }
.info-value { font-size: 26rpx; font-weight: bold; color: #14213d; }
.reward-text { color: #3949ab; }

.progress-card {
	padding: 28rpx 24rpx;
	border-radius: 28rpx;
	background: rgba(255, 253, 250, 0.97);
	border: 1px solid rgba(20, 33, 61, 0.06);
	box-shadow: 0 12rpx 32rpx rgba(31, 41, 55, 0.08);
	margin-bottom: 18rpx;
}

.progress-title {
	font-size: 28rpx;
	font-weight: 700;
	color: #14213d;
	margin-bottom: 18rpx;
}

.condition-item {
	display: flex;
	align-items: center;
	padding: 18rpx;
	border-radius: 18rpx;
}
.condition-item .cond-icon { margin-right: 14rpx; }

.cond-done { background: rgba(52, 199, 89, 0.08); }
.cond-pending { background: rgba(20, 33, 61, 0.04); }

.cond-icon { font-size: 36rpx; }
.cond-text { font-size: 26rpx; color: #14213d; flex: 1; }

.checkin-preview {
	margin-top: 16rpx;
}

.checkin-img {
	width: 100%;
	height: 300rpx;
	border-radius: 18rpx;
}

.checkin-note {
	margin-top: 10rpx;
	font-size: 24rpx;
	color: #6b7280;
	line-height: 1.5;
}

.action-area { margin-top: 8rpx; }

.nav-btn {
	width: 100%;
	height: 96rpx;
	border-radius: 26rpx;
	font-size: 30rpx;
	font-weight: 700;
	background: linear-gradient(135deg, #3949ab 0%, #283593 100%);
	color: #fff;
	box-shadow: 0 20rpx 40rpx rgba(57, 73, 171, 0.25);
}

.nav-btn:active { transform: scale(0.98); }

.loading {
	display: flex;
	justify-content: center;
	padding-top: 120rpx;
	color: #9aa6b2;
}
</style>
