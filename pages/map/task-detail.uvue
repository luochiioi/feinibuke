<template>
	<view class="detail-page">
		<view v-if="hasTask" class="content">
			<view class="status-banner" :class="taskStatusClass">
				<text class="banner-icon">{{ taskBannerIcon }}</text>
				<text class="banner-text">{{ taskBannerText }}</text>
			</view>

			<view class="info-card">
				<text class="task-title">{{ taskName }}</text>
				<text class="task-desc">{{ taskDesc }}</text>

				<view class="info-row">
					<text class="info-label">目标景点</text>
					<text class="info-value">{{ taskTargetTitle }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">任务奖励</text>
					<text class="info-value reward-text">{{ taskReward }}</text>
				</view>
				<view class="info-row" v-if="taskCompleted && taskCompletedAtStr != ''">
					<text class="info-label">完成时间</text>
					<text class="info-value">{{ taskCompletedAtStr }}</text>
				</view>
			</view>

			<view class="progress-card">
				<text class="progress-title">完成条件</text>
				<view class="condition-item" :class="checkConditionClass">
					<text class="cond-icon">{{ checkIcon }}</text>
					<text class="cond-text">前往 {{ taskTargetTitle }} 完成拍照打卡</text>
				</view>
				<view v-if="checkedPhotoPath != ''" class="checkin-preview">
					<image class="checkin-img" :src="checkedPhotoPath" mode="aspectFill" @click="previewPhoto(checkedPhotoPath)" />
					<text v-if="checkedNote != ''" class="checkin-note">{{ checkedNote }}</text>
				</view>
			</view>

			<view v-if="isPending" class="action-area">
				<button class="nav-btn" @click="goToMap">前往景点打卡</button>
			</view>
		</view>

		<view v-else class="loading">
			<text>加载中…</text>
		</view>
	</view>
</template>

<script lang="ts">
import { formatDateTime, getMarkers } from '@/utils/map-utils.uts';
import { taskStore } from '@/store/taskStore.uts';

export default {
	data() {
		return {
			rawTask: null as UTSJSONObject | null,
			rawCheckedMarker: null as UTSJSONObject | null
		};
	},
	computed: {
		hasTask(): boolean {
			return this.rawTask != null;
		},
		taskStatusClass(): string {
			const s = this.rawTask == null ? '' : (this.rawTask["status"] as string);
			return s === 'completed' ? 'banner-done' : 'banner-pending';
		},
		taskBannerIcon(): string {
			const s = this.rawTask == null ? '' : (this.rawTask["status"] as string);
			return s === 'completed' ? '\uD83C\uDF89' : '\uD83D\uDDFA';
		},
		taskBannerText(): string {
			const s = this.rawTask == null ? '' : (this.rawTask["status"] as string);
			return s === 'completed' ? '\u4EFB\u52A1\u5DF2\u5B8C\u6210' : '\u4EFB\u52A1\u8FDB\u884C\u4E2D';
		},
		taskName(): string {
			return this.rawTask == null ? '' : (this.rawTask["name"] as string);
		},
		taskDesc(): string {
			return this.rawTask == null ? '' : (this.rawTask["description"] as string);
		},
		taskTargetTitle(): string {
			return this.rawTask == null ? '' : (this.rawTask["targetTitle"] as string);
		},
		taskReward(): string {
			return this.rawTask == null ? '' : (this.rawTask["reward"] as string);
		},
		isCompleted(): boolean {
			const s = this.rawTask == null ? '' : (this.rawTask["status"] as string);
			return s === 'completed';
		},
		isPending(): boolean {
			return !this.isCompleted && this.hasTask;
		},
		taskCompleted(): boolean {
			return this.isCompleted;
		},
		taskCompletedAtStr(): string {
			if (!this.isCompleted || this.rawTask == null) return '';
			const v = this.rawTask["completedAt"];
			if (v != null && typeof v === 'number') return formatDateTime(v);
			return '';
		},
		checkConditionClass(): string {
			return this.rawCheckedMarker != null ? 'cond-done' : 'cond-pending';
		},
		checkIcon(): string {
			return this.rawCheckedMarker != null ? '\u2705' : '\u2B1C';
		},
		checkedPhotoPath(): string {
			if (this.rawCheckedMarker == null) return '';
			const p = this.rawCheckedMarker["photoPath"];
			return (p != null && typeof p === 'string') ? (p as string) : '';
		},
		checkedNote(): string {
			if (this.rawCheckedMarker == null) return '';
			const n = this.rawCheckedMarker["note"];
			return (n != null && typeof n === 'string') ? (n as string) : '';
		}
	},
	onLoad(query: UTSJSONObject) {
		const id = query["id"];
		if (id != null) this.loadTask(id as string);
	},
	onShow() {
		if (this.hasTask) this.loadTask('' + (this.rawTask as UTSJSONObject)["id"]);
	},
	methods: {
		async loadTask(id: string) {
			// P0-#7：合并逻辑统一收敛到 taskStore，本页面不再重写 task_list+user_tasks 合并
			if (taskStore.loadedAt() === 0) {
				await taskStore.refresh();
			}
			const merged = taskStore.getById(id);
			if (merged == null) return;
			this.rawTask = merged;

			// find corresponding checkin record
			const markers = getMarkers();
			this.rawCheckedMarker = null;
			const targetTitle = merged["targetTitle"] as string;
			for (let i = 0; i < markers.length; i++) {
				const mk = markers[i] as UTSJSONObject;
				const matchesId = '' + mk["id"] === id;
				const matchesTitle = '' + mk["title"] === targetTitle;
				if ((matchesId || matchesTitle) && mk["checked"] === true) {
					this.rawCheckedMarker = mk;
					break;
				}
			}
		},
		goToMap() {
			const tasksRaw = uni.getStorageSync('task_list');
			let tasks: Array<UTSJSONObject> = [];
			if (tasksRaw != null && Array.isArray(tasksRaw)) {
				tasks = tasksRaw as Array<UTSJSONObject>;
			}
			if (this.rawTask == null) return;
			const tid = '' + (this.rawTask as UTSJSONObject)["id"];
			let targetMarker: UTSJSONObject | null = null;
			for (let i = 0; i < tasks.length; i++) {
				const t = tasks[i] as UTSJSONObject;
				if ('' + t["id"] === tid) {
					const markers = getMarkers();
					const tid2 = '' + t["targetMarkerId"];
					const ttitle = t["targetTitle"] as string;
					for (let j = 0; j < markers.length; j++) {
						const m = markers[j] as UTSJSONObject;
						if ('' + m["id"] === tid2 || '' + m["title"] === ttitle) {
							targetMarker = m;
							break;
						}
					}
					break;
				}
			}
			if (targetMarker != null) {
				// P1-#9：路由 query 替代 uni.$emit 事件总线，消除 emit 与 once 注册的时序竞态
				const fid = '' + targetMarker["id"];
				const flat = '' + targetMarker["latitude"];
				const flng = '' + targetMarker["longitude"];
				uni.navigateTo({ url: `/pages/map/index?focusId=${fid}&lat=${flat}&lng=${flng}` });
			} else {
				uni.navigateTo({ url: '/pages/map/index' });
			}
		},
		previewPhoto(path: string) {
			if (typeof path === 'string' && path.length > 0) {
				uni.previewImage({ urls: [path], current: path });
			}
		}
	}
};
</script>

<style scoped>
.detail-page {
	flex: 1;
	background: linear-gradient(180deg, #f4f7ff 0%, #f8faff 100%);
	padding: 20rpx 24rpx 80rpx;
}

