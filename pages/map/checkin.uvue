	letter-spacing: 3rpx;
	color: #007aff;
}

.hero-title {
	margin-top: 16rpx;
	font-size: 50rpx;
	font-weight: 700;
	color: #1a2a4a;
	line-height: 1.2;
}

.hero-subtitle {
	margin-top: 10rpx;
	font-size: 24rpx;
	color: #5b6475;
}

