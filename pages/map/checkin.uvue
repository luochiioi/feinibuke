<template>
	<view class="checkin-page">
		<view class="hero-section">
			<text class="hero-tag">PHOTO CHECK-IN</text>
			<text class="hero-title">{{ markerTitle }}</text>
			<text class="hero-subtitle">拍一张照片，记录你到访这里的瞬间。</text>
		</view>

		<view class="content-card photo-card">
			<view class="section-head">
				<text class="section-title">打卡照片</text>
				<text class="section-note">最多选 1 张，建议 < 1MB</text>
			</view>

			<view class="photo-area" @click="choosePhoto">
				<view v-if="photoPath" class="photo-preview-wrap">
					<image class="photo-preview" :src="photoPath" mode="aspectFill" />
					<view class="photo-change-mask">
						<text class="photo-change-text">点击更换</text>
					</view>
				</view>
				<view v-else class="photo-placeholder">
					<text class="placeholder-icon">📷</text>
					<text class="placeholder-text">点击拍照或选择图片</text>
				</view>
			</view>

			<view v-if="photoSize" class="photo-meta">
				<text class="photo-meta-text">图片大小：{{ photoSize }}</text>
				<text v-if="compressed" class="photo-meta-compressed">已压缩</text>
			</view>
		</view>

		<view class="content-card note-card">
			<view class="section-head">
				<text class="section-title">打卡备注</text>
				<text class="section-note">选填</text>
			</view>
			<textarea
				v-model="note"
				class="note-input"
				placeholder="记录一下此刻的感受……"
				maxlength="200"
				:auto-height="true"
			/>
			<text class="note-count">{{ note.length }}/200</text>
		</view>

		<view class="content-card location-card">
			<view class="section-head">
				<text class="section-title">当前距离</text>
			</view>
			<view class="dist-row">
				<text class="dist-value" :class="canCheckin ? 'dist-ok' : 'dist-far'">
					{{ distanceText }}
				</text>
				<text class="dist-hint" v-if="!canCheckin && distance !== '--'">
					请靠近景点 {{ needMore }} 米后打卡
				</text>
				<text class="dist-hint dist-ok-hint" v-if="canCheckin">
					距离满足，可以打卡了！
				</text>
			</view>
		</view>

		<view class="action-row">
			<button class="secondary-btn" @click="goBack">取消</button>
			<button
				class="primary-btn"
				:class="{ 'btn-disabled': submitting || !canCheckin }"
				:disabled="submitting || !canCheckin"
				@click="submit"
			>
				{{ submitting ? '提交中…' : '完成打卡' }}
			</button>
		</view>
	</view>
</template>

<script lang="ts">
import { getMarkers } from '@/utils/map-storage.uts';
import { haversine } from '@/utils/geo.uts';
import { markerStore } from '@/store/markerStore.uts';

const CHECKIN_RADIUS = 500; // 米

export default {
	data() {
		return {
			markerId: null,
			markerTitle: '景点打卡',
			photoPath: '',
			photoSize: '',
			compressed: false,
			note: '',
			locLat: 0.0,
			locLng: 0.0,
			hasLocation: false,
			distance: '--',
			submitting: false
		};
	},
	computed: {
		canCheckin() {
			if (this.distance === '--') return false;
			return parseFloat(this.distance) <= CHECKIN_RADIUS;
		},
		distanceText() {
			if (this.distance === '--') return '正在获取位置…';
			const d = parseFloat(this.distance);
			return d >= 1000 ? `${(d / 1000).toFixed(2)} 千米` : `${d} 米`;
		},
		needMore() {
			if (this.distance === '--') return '--';
			return Math.max(0, parseFloat(this.distance) - CHECKIN_RADIUS);
		}
	},
	onLoad(query) {
		const idRaw = query != null ? query["id"] : null;
		const titleRaw = query != null ? query["title"] : null;
		this.markerId = idRaw != null ? parseInt('' + idRaw) : 0;
		const titleStr = titleRaw != null ? '' + titleRaw : '景点打卡';
		this.markerTitle = decodeURIComponent(titleStr) ?? titleStr;
		this.getLocation();
	},
	methods: {
		getLocation() {
			uni.getLocation({
				type: 'gcj02',
				isHighAccuracy: true,
				highAccuracyExpireTime: 8000,
				success: (res) => {
					this.locLat = res.latitude;
					this.locLng = res.longitude;
					this.hasLocation = true;
					this.calcDistance();
				},
				fail: () => {
					uni.showToast({ title: '获取定位失败', icon: 'none' });
				}
			});
		},
		calcDistance() {
			if (!this.hasLocation) return;
			const markers = getMarkers();
			const target = markers.find(m => {
				const mo = m as UTSJSONObject;
				return mo["id"] == this.markerId;
			});
			if (target == null) return;
			const to = target as UTSJSONObject;
			const targetLatRaw = to["latitude"];
			const targetLngRaw = to["longitude"];
			if (targetLatRaw == null || targetLngRaw == null) return;
			this.distance = '' + haversine(
				this.locLat,
				this.locLng,
				parseFloat('' + targetLatRaw),
				parseFloat('' + targetLngRaw)
			);
		},
		choosePhoto() {
			uni.showActionSheet({
				itemList: ['拍照', '从相册选择'],
				success: (res) => {
					const sourceType = res.tapIndex === 0 ? ['camera'] : ['album'];
					uni.chooseImage({
						count: 1,
						sizeType: ['compressed'],
						sourceType,
						success: (imgRes) => {
							const tempPath = imgRes.tempFilePaths[0];
							this.checkAndSetPhoto(tempPath);
						}
					});
				}
			});
		},
		checkAndSetPhoto(path : string) {
			this.photoPath = path;
			this.compressed = false;
			this.photoSize = '';
			uni.compressImage({
				src: path,
				quality: 70,
				success: (compRes) => {
					this.photoPath = compRes.tempFilePath;
					this.compressed = true;
					this.photoSize = '（已压缩）';
				},
				fail: () => {
					// keep original
				}
			});
		},
		updateSizeLabel(path : string) {
			// no-op: file size API unavailable on this platform
		},
		async submit() {
			if (this.submitting || !this.canCheckin) return;
			this.submitting = true;
			uni.showLoading({ title: '打卡中…', mask: true });

			const idStr = '' + this.markerId;
			try {
				const payload = {} as UTSJSONObject;
				if (this.photoPath != '') {
					payload["photoPath"] = this.photoPath;
				}
				const trimmedNote = this.note.trim();
				if (trimmedNote != '') {
					payload["note"] = trimmedNote;
				}

				const completedTasks = await markerStore.checkInOptimistic(idStr, payload);

				uni.hideLoading();
				uni.showToast({ title: '打卡成功！', icon: 'success' });
				if (completedTasks.length > 0) {
					const firstName = '' + completedTasks[0]["name"];
					setTimeout((): void => {
						uni.showToast({ title: `任务完成：${firstName}`, icon: 'none', duration: 2500 });
					}, 900);
				}
				setTimeout((): void => {
					this.submitting = false;
					uni.navigateBack();
				}, 800);
			} catch (e) {
				uni.hideLoading();
				uni.showToast({ title: '打卡失败，请重试', icon: 'none' });
				this.submitting = false;
			}
		},
		goBack() {
			uni.navigateBack();
		}
	}
};
</script>

<style scoped>
