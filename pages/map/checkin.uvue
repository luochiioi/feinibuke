	padding: 28rpx 24rpx;
	border-radius: 30rpx;
	background: rgba(255, 253, 250, 0.96);
	border: 1px solid rgba(20, 33, 61, 0.06);
	box-shadow: 0 16rpx 40rpx rgba(31, 41, 55, 0.08);
	margin-bottom: 18rpx;
}

