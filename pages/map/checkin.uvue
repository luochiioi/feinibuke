	display: flex;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 20rpx;
}

.section-title {
	font-size: 30rpx;
	font-weight: 700;
	color: #14213d;
}

.section-note {
	font-size: 21rpx;
	color: #7b8496;
}

/* 照片区域 */
.photo-area {
	border-radius: 22rpx;
	overflow: hidden;
	background: #f0f4fb;
	border: 2px dashed #c5d3e8;
}

.photo-placeholder {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	height: 340rpx;
}

.placeholder-icon { font-size: 72rpx; }
.placeholder-text { font-size: 26rpx; color: #8b9ab5; margin-top: 16rpx; }

.photo-preview-wrap {
	position: relative;
	height: 400rpx;
}

.photo-preview {
	width: 100%;
	height: 100%;
}

.photo-change-mask {
	position: absolute;
	bottom: 0; left: 0; right: 0;
	padding: 18rpx;
	background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
	display: flex;
	justify-content: center;
}

.photo-change-text { color: #fff; font-size: 24rpx; }

.photo-meta {
	display: flex;
	align-items: center;
	/* gap removed - use margin instead */
	margin-top: 12rpx;
}

.photo-meta-text { font-size: 22rpx; color: #7b8496; }
.photo-meta-compressed {
	font-size: 20rpx;
	padding: 4rpx 10rpx;
	border-radius: 999rpx;
	background: rgba(52, 199, 89, 0.1);
	color: #34c759;
}

/* 备注 */
.note-input {
	width: 100%;
	min-height: 140rpx;
	padding: 18rpx;
	border-radius: 18rpx;
	background: #f7f9fc;
	border: 1px solid rgba(20, 33, 61, 0.07);
	font-size: 26rpx;
	color: #14213d;
	box-sizing: border-box;
}

.note-count {
	text-align: right;
	margin-top: 8rpx;
	font-size: 20rpx;
	color: #aab3c0;
}

/* 距离 */
.dist-row { display: flex; flex-direction: column; }
.dist-row .dist-value { margin-bottom: 10rpx; }

.dist-value {
	font-size: 46rpx;
	font-weight: 700;
}

.dist-ok { color: #34c759; }
.dist-far { color: #ff9500; }

.dist-hint { font-size: 24rpx; color: #7b8496; }
.dist-ok-hint { color: #34c759; }

/* 操作按钮 */
.action-row {
	display: flex;
	margin-top: 8rpx;
}
.action-row .secondary-btn { margin-right: 14rpx; }

.primary-btn, .secondary-btn {
	height: 96rpx;
	border-radius: 26rpx;
	font-size: 30rpx;
	font-weight: 700;
}

.primary-btn {
	flex: 1;
	background: linear-gradient(135deg, #007aff 0%, #0056d0 100%);
	color: #fff;
	box-shadow: 0 20rpx 40rpx rgba(0, 122, 255, 0.25);
}

.btn-disabled {
	background: #c0c8d8;
	box-shadow: none;
}

