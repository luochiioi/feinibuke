  width: 140rpx;
  height: 140rpx;
  background-color: #fff;
  border-radius: 70rpx; /* 修复 50% */
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.tip {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.sub-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.go-btn {
  width: 240rpx;
  height: 80rpx;
  background-image: linear-gradient(to right, #7b61ff, #9c88ff);
  color: white;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

/* 列表区域 */
.items-scroll {
  flex: 1;
}

.items-container {
  padding: 30rpx;
}

.favorite-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  flex-direction: row; 
}

.fav-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background-color: #f0f0f0;
}

.fav-content {
  flex: 1;
  margin-left: 24rpx;
  justify-content: space-between;
  padding-right: 40rpx; 
}

.fav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.fav-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.fav-footer-info {
  flex-direction: row;
  align-items: center;
}

.fav-area-tag {
  font-size: 20rpx;
  color: #7b61ff;
  background-color: #f4f1ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.fav-time {
  font-size: 22rpx;
  color: #bbb;
}

.delete-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 25rpx; /* 修复 */
  align-items: center;
  justify-content: center;
}
</style>