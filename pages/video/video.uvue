<template>
  <view class="video-page">
    <view class="background-texture"></view>

    <view class="custom-header">
      <view class="search-bar">
        <view class="search-input">
          <uni-icons type="search" size="18" color="#999"></uni-icons>
          
          <input 
            class="real-input" 
            type="text" 
            placeholder="搜索非遗视频 / 作者" 
            placeholder-style="color:#999"
            v-model="searchKeyword"
            confirm-type="search"
          />
          
          <view v-if="searchKeyword.length > 0" @click="clearSearch" style="padding: 0 10px;">
             <uni-icons type="clear" size="18" color="#ccc"></uni-icons>
          </view>
        </view>
      </view>
    </view>

    <scroll-view class="main-scroll" scroll-y="true" :show-scrollbar="true">
      
      <view class="header-spacer"></view>

      <view class="content-section">
        <view class="section-header">
          <text class="section-title">精彩推荐</text>
        </view>
        
        <view class="swiper-wrapper">
          <swiper 
            class="banner-swiper" 
            :circular="true" 
            :autoplay="true" 
            :interval="3000" 
            :duration="500"
            :indicator-dots="false" 
            @change="onSwiperChange"
          >
            <swiper-item v-for="(item, index) in topRecommendList" :key="index">
              <view class="swiper-item-content" :style="{ backgroundColor: item.color }">
                <text class="swiper-desc">{{ item.desc }}</text>
                <view class="swiper-tag">
                  <text class="swiper-tag-text">热门</text>
                </view>
              </view>
            </swiper-item>
          </swiper>

          <view class="custom-dots">
            <view 
              class="dot" 
              :class="{ 'dot-active': currentSwiper === index }" 
              v-for="(item, index) in topRecommendList" 
              :key="index"
            ></view>
          </view>
        </view>
      </view>

      <view class="category-section">
        <scroll-view scroll-x="true" class="tags-scroll" :show-scrollbar="false" direction="horizontal">
          <view class="tags-wrapper">
            <view 
              class="tag-item" 
              :class="{ 'tag-active': currentCategory === tag.id }"
              v-for="(tag, index) in categoryList" 
              :key="index"
              @click="switchCategory(tag.id)"
            >
              <text :class="currentCategory === tag.id ? 'tag-text-active' : 'tag-text'">{{ tag.name }}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="content-section">
        <view class="section-header">
          <text class="section-title">{{ currentCategoryName }}视频区</text>
        </view>

        <view class="video-list">
          <view class="video-item" v-for="(item, index) in filteredVideoList" :key="index">
            <view class="video-cover" :style="{ backgroundColor: item.color }">
               <uni-icons type="plusempty" size="30" color="#fff" style="opacity:0.5"></uni-icons>
            </view>
            <view class="video-info">
              <text class="video-title" style="lines: 2; text-overflow: ellipsis;">{{ item.title }}</text>
              <view class="video-meta">
                <text class="video-stats">播放：{{ item.views }}</text>
                <text class="video-author">{{ item.author }}</text>
              </view>
              <view class="video-tag-row">
                 <text class="video-mini-tag">{{ getCategoryName(item.categoryId) }}</text>
              </view>
            </view>
          </view>
          
          <view v-if="filteredVideoList.length === 0" style="padding: 60rpx; align-items: center;">
             <text style="color: #999; font-size: 26rpx;">未找到相关内容</text>
          </view>
          
          <view style="height: 60rpx;"></view>
        </view>
      </view>

      <view class="page-footer">
        <text class="footer-text">© 2025 非你不可</text>
      </view>

    </scroll-view>
  </view>
</template>

<script>
type RecItem = { color: string, desc: string }
type CategoryItem = { name: string, id: string }
type VideoItem = { color: string, title: string, views: number, author: string, categoryId: string }

export default {
  data() {
    return {
      searchKeyword: "", 
      currentCategory: "all",
      currentSwiper: 0,
      
      categoryList: [
        { name: "全部", id: "all" },
        { name: "传统技艺", id: "craft" },
        { name: "非遗美食", id: "food" },
        { name: "戏曲艺术", id: "opera" },
        { name: "民俗活动", id: "custom" },
      ] as CategoryItem[],

      topRecommendList: [
        { color: "#9FA8DA", desc: "指尖经纬：一针一线里的湘绣传奇" },
        { color: "#FFAB91", desc: "舌尖上的非遗：探秘宫廷御膳制作" },
        { color: "#80CBC4", desc: "泥土的歌唱：千年景德镇陶瓷" }
      ] as RecItem[],

      allVideos: [
        { color: "#BBDEFB", title: "当千年湘绣遇见现代时装，这波有多绝？", views: 1200, author: "非遗传承人", categoryId: "craft" },
        { color: "#FFF59D", title: "竹编艺术：不仅是器物，更是生活的哲学", views: 340, author: "竹编大师", categoryId: "craft" },
        { color: "#FFCCBC", title: "舌尖上的顺德：古法双皮奶的制作秘密", views: 5600, author: "寻味中华", categoryId: "food" },
        { color: "#C5E1A5", title: "老北京炸酱面：一碗面里的讲究", views: 890, author: "老味道", categoryId: "food" },
        { color: "#F8BBD0", title: "昆曲《牡丹亭》选段欣赏", views: 210, author: "梨园春", categoryId: "opera" },
        { color: "#B2DFDB", title: "皮影戏幕后的故事：光影间的千年传承", views: 3300, author: "光影匠人", categoryId: "custom" },
        { color: "#FFCC80", title: "端午赛龙舟：力量与团结的象征", views: 4500, author: "民俗记录", categoryId: "custom" },
        { color: "#CE93D8", title: "京剧脸谱的色彩学问：红忠白奸", views: 1200, author: "国粹馆", categoryId: "opera" },
        { color: "#90CAF9", title: "景泰蓝制作工艺流程大揭秘", views: 8800, author: "非遗百科", categoryId: "craft" },
        { color: "#EF9A9A", title: "四川火锅底料炒制：麻辣鲜香的灵魂", views: 9999, author: "川味", categoryId: "food" }
      ] as VideoItem[]
    };
  },
  computed: {
    filteredVideoList(): VideoItem[] {
      let result = this.allVideos;
      if (this.currentCategory !== "all") {
        result = result.filter((item: VideoItem): boolean => item.categoryId === this.currentCategory);
      }
      const keyword = this.searchKeyword.trim().toLowerCase();
      if (keyword !== "") {
        result = result.filter((item: VideoItem): boolean => {
          return item.title.toLowerCase().includes(keyword) || 
                 item.author.toLowerCase().includes(keyword);
        });
      }
      return result;
    },
    currentCategoryName(): string {
      const item = this.categoryList.find((c: CategoryItem): boolean => c.id === this.currentCategory);
      return item != null ? item.name : "全部";
    }
  },
  methods: {
    switchCategory(id: string) {
      this.currentCategory = id;
    },
    getCategoryName(id: string): string {
       const item = this.categoryList.find((c: CategoryItem): boolean => c.id === id);
       return item != null ? item.name : "";
    },
    onSwiperChange(e: SwiperChangeEvent) {
      this.currentSwiper = e.detail.current;
    },
    clearSearch() {
      this.searchKeyword = "";
    }
  }
};
</script>

<style scoped>
