  flex-direction: column; 
}
.video-item {
  flex-direction: row; 
  align-items: flex-start;
  margin-bottom: 30rpx; 
  background-color: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}
.video-cover {
  width: 220rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  justify-content: center;
  align-items: center;
}
.video-info {
  flex: 1;
  flex-direction: column; 
  justify-content: space-between;
  min-height: 140rpx;
}
.video-title {
  font-size: 28rpx;
