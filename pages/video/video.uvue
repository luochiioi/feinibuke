  padding: 0 15px;
  height: 44px;
  justify-content: center;
}

.search-input {
  background-color: #f7f7f7;
  height: 36px;
  border-radius: 18px;
  flex-direction: row; 
  align-items: center;
  padding: 0 10px;
}

.real-input {
  flex: 1;
  font-size: 14px;
  color: #333;
  margin-left: 5px;
  background-color: transparent;
}

/* 4. 【核心修复】主滚动区域 */
/* 直接使用 flex: 1 填满剩余空间，并设置 overflow: hidden */
.main-scroll {
  flex: 1;
  width: 100%;
  overflow: hidden; /* 防止 flex 子项溢出 */
  /* 如果上面 flex: 1 不生效，可以尝试打开下面这行强制高度为0，迫使重新计算 */
  /* height: 0px; */ 
}

/* 5. 头部间距：现在只需要一点点空隙即可 */
.header-spacer {
  height: 10px;
  width: 100%;
}

/* --- 以下内容样式保持不变 --- */

.content-section {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
  padding-top: 10rpx;
}
