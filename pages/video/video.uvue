.video-page {
  width: 100%;
  height: 100%; /* uni-app x 推荐用 100% 适配根视图 */
  display: flex;
  flex-direction: column;
  background-color: #FDFCF8;
}

/* 2. 背景：绝对定位 */
.background-texture {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: -1;
}

/* 3. 头部导航：固定在顶部，不参与 Flex 伸缩 */
/* 这里不再用 absolute，而是直接占据文档流空间 */
.custom-header {
  width: 100%;
  background-color: #ffffff;
  z-index: 999;
  flex-shrink: 0; /* 防止被压缩 */
  padding-top: 44px; 
  padding-bottom: 10px;
}

