  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #e8f8e8 0%, #f0faf0 40%, #e8f8e8 100%);
  position: relative;
}

.login-content {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.login-card {
  width: 100%;
  background-color: #ffffff;
  padding: 60rpx 50rpx;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(46, 204, 113, 0.12);
  border: 2rpx solid #e0f5e0;
}

.title {
  font-size: 52rpx;
  color: #2ecc71;
  font-weight: bold;
  margin-bottom: 16rpx;
  text-align: center;
}

.subtitle {
  font-size: 26rpx;
  color: #9ab89a;
  text-align: center;
  margin-bottom: 60rpx;
}

.input-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  border-bottom: 2rpx solid #2ecc71;
  padding-bottom: 20rpx;
  margin-bottom: 50rpx;
  width: 100%;
}

.custom-input {
  flex: 1;
  height: 60rpx;
  font-size: 32rpx;
  color: #333333;
}

.placeholder-style {
  color: #aabb99;
  font-size: 28rpx;
}

.captcha-group {
  justify-content: space-between;
}

.get-captcha-btn {
  font-size: 28rpx;
  color: #2ecc71;
  padding-left: 30rpx;
  border-left: 2rpx solid #d0f0d0;
  height: 60rpx;
  line-height: 60rpx;
}

.confirm-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background-color: #2ecc71;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 45rpx;
  margin-top: 60rpx;
  box-shadow: 0 8rpx 16rpx rgba(46, 204, 113, 0.3);
}

.btn-hover {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 8rpx rgba(46, 204, 113, 0.3);
  opacity: 0.9;
}
</style>
