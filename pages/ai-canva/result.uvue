  color: #2c2213;
  font-size: 24px;
  font-weight: 700;
}

.page-desc {
  margin-top: 8px;
  color: #756244;
  font-size: 14px;
  line-height: 20px;
}

.badge {
  padding: 8px 12px;
  border-radius: 999px;
  background: #ebfaf7;
  color: #0f766e;
  font-size: 12px;
  font-weight: 700;
}

.state-panel,
.result-panel {
  margin-top: 20px;
}

.state-panel {
  padding: 18px;
  border-radius: 20px;
  background: #fbf7ef;
  align-items: center;
}

.state-error {
  background: #fff4ef;
}

.spinner {
  width: 42px;
  height: 42px;
  border-radius: 999px;
  border-width: 4px;
  border-style: solid;
  border-color: rgba(15, 118, 110, 0.18);
  border-top-color: #0f766e;
}

.state-title {
  margin-top: 12px;
  color: #2c2213;
  font-size: 18px;
  font-weight: 700;
}

.state-desc,
.state-meta,
.tips-text,
.prompt-text {
  margin-top: 8px;
  color: #715f43;
  font-size: 13px;
  line-height: 20px;
}

.result-image {
  width: 100%;
  border-radius: 22px;
  background: #ffffff;
}

.meta-row {
  margin-top: 16px;
  flex-wrap: wrap;
  /* gap removed - uvue doesn't support gap */
}

.meta-card,
.prompt-box,
.tips-box {
  padding: 14px;
  border-radius: 18px;
  background: #fbf7ef;
}

.meta-card {
  flex: 1;
  min-width: 120px;
}

.meta-label {
  color: #7f6943;
  font-size: 12px;
  font-weight: 700;
}

.meta-value,
.tips-title {
  margin-top: 6px;
  color: #2d2315;
  font-size: 15px;
  font-weight: 700;
}

.prompt-box,
.tips-box {
  margin-top: 14px;
}

.action-row {
  margin-top: 18px;
  flex-wrap: wrap;
}
.action-row .ghost-btn + .ghost-btn { margin-left: 12px; }

.primary-btn,
.secondary-btn,
.ghost-btn {
  min-width: 128px;
  height: 46px;
  padding-left: 18px;
  padding-right: 18px;
  border-radius: 16px;
  justify-content: center;
  align-items: center;
  font-size: 14px;
  font-weight: 700;
}

.primary-btn {
  background: linear-gradient(135deg, #203331 0%, #0f766e 100%);
  color: #ffffff;
}

.secondary-btn,
.ghost-btn {
  background: #efe6d5;
  color: #3a2e1c;
}

@media screen and (min-width: 768px) {
  .page-inner {
    width: 760px;
    margin-left: auto;
    margin-right: auto;
  }
}
</style>


