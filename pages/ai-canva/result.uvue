  padding: 20px;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(84, 66, 38, 0.1);
  box-shadow: 0 14px 40px rgba(71, 56, 30, 0.08);
}

.title-row,
.action-row,
.meta-row {
  flex-direction: row;
}

.title-row {
  justify-content: space-between;
  align-items: center;
}

